body {
    margin: 0;
    font-family: 'Segoe UI';
    background: linear-gradient(135deg, #74ebd5, #9face6);
    color: #333;
    text-align: center;
    scroll-behavior: smooth;
}

header {
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 15px;
}

nav {
    background: rgba(0,0,0,0.6);
    padding: 10px;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
    transition: 0.3s;
}

nav a:hover {
    color: yellow;
}

section {
    padding: 40px 20px;
}

.profile {
    width: 160px;
    border-radius: 50%;
    border: 4px solid white;
    box-shadow: 0 0 20px rgba(0,0,0,0.3);
}

.card {
    display: inline-block;
    width: 220px;
    margin: 15px;
    padding: 15px;
    border-radius: 15px;
    background: white;
    transition: transform 0.4s, box-shadow 0.4s;
}

.card:hover {
    transform: translateY(-10px) scale(1.05);
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}

.card img {
    width: 100%;
    border-radius: 10px;
}

#gallery img {
    width: 150px;
    margin: 10px;
    border-radius: 10px;
    transition: 0.3s;
}

#gallery img:hover {
    transform: scale(1.2);
}

footer {
    background: black;
    color: white;
    padding: 10px;
}

/* Animations */
.fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: 1s;
}

.fade-in.show {
    opacity: 1;
    transform: translateY(0);
}

/* Dark Mode */
.dark {
    background: #121212;
    color: white;
}

.dark nav {
    background: #222;
}

.dark .card {
    background: #333;
}