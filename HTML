    <title>Md. Farhan Shaikh | Digital Portfolio</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>
<body>

    <div class="background-blobs">
        <div class="blob"></div>
        <div class="blob"></div>
    </div>

    <nav>
        <div class="logo">Farhan<span>.</span></div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#achievements">Achievements</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#gallery">Gallery</a></li>
        </ul>
        <button id="theme-toggle"><i class="fas fa-adjust"></i></button>
    </nav>

    <section id="home" class="hero">
        <div class="hero-content" data-aos="fade-up">
            <div class="profile-container">
                <img src="assets/profile.jpg" alt="Md. Farhan Shaikh" class="profile-pic">
            </div>
            <h1>Md. Farhan Shaikh</h1>
            <p class="typing-text">Passionate Student & Aspiring Software Engineer</p>
            <div class="hero-btns">
                <a href="#projects" class="btn primary">View My Work</a>
                <a href="#contact" class="btn secondary">Contact Me</a>
            </div>
        </div>
    </section>

    <section id="about">
        <h2 class="section-header" data-aos="fade-right">About Me</h2>
        <div class="about-grid">
            <div class="about-card" data-aos="zoom-in" data-aos-delay="100">
                <i class="fas fa-university"></i>
                <h3>Education</h3>
                <p>MIT VishwaPrayag University</p>
            </div>
            <div class="about-card" data-aos="zoom-in" data-aos-delay="200">
                <i class="fas fa-lightbulb"></i>
                <h3>Interests</h3>
                <p>AI & Web Development</p>
            </div>
            <div class="about-card" data-aos="zoom-in" data-aos-delay="300">
                <i class="fas fa-rocket"></i>
                <h3>Goals</h3>
                <p>Become a Software Engineer</p>
            </div>
            <div class="about-card" data-aos="zoom-in" data-aos-delay="400">
                <i class="fas fa-brain"></i>
                <h3>Strengths</h3>
                <p>Problem solving, Creativity</p>
            </div>
        </div>
    </section>

    <section id="achievements">
        <h2 class="section-header" data-aos="fade-right">Achievements & Certificates</h2>
        <div class="cert-grid">
            <div class="cert-card" data-aos="flip-left">
                <div class="cert-icon"><i class="fas fa-certificate"></i></div>
                <h3>MATLAB Certificate</h3>
                <p>Issued by Coursera</p>
                <a href="assets/matlab-cert.pdf" target="_blank" class="view-btn">View Certificate <i class="fas fa-external-link-alt"></i></a>
            </div>
            <div class="cert-card" data-aos="flip-left" data-aos-delay="100">
                <div class="cert-icon"><i class="fas fa-award"></i></div>
                <h3>ACE Certificate</h3>
                <p>Career Excellence Program</p>
                <a href="assets/ace-cert.pdf" target="_blank" class="view-btn">View Certificate <i class="fas fa-external-link-alt"></i></a>
            </div>
            <div class="cert-card" data-aos="flip-left" data-aos-delay="200">
                <div class="cert-icon"><i class="fas fa-microchip"></i></div>
                <h3>Netcad / Yuva AI</h3>
                <p>Networking & AI Basics</p>
                <a href="assets/yuva-ai.pdf" target="_blank" class="view-btn">View Certificate <i class="fas fa-external-link-alt"></i></a>
            </div>
        </div>
    </section>

    <section id="projects">
        <h2 class="section-header" data-aos="fade-right">Featured Projects</h2>
        <div class="project-list">
            <div class="project-item" data-aos="fade-left">
                <div class="project-info">
                    <h3>Ai4A Project</h3>
                    <p>Detailed research and implementation of AI for All initiatives.</p>
                </div>
            </div>
            <div class="project-item" data-aos="fade-right">
                <div class="project-info">
                    <h3>Design Thinking</h3>
                    <p>Applying user-centric methodologies to solve real-world problems.</p>
                </div>
            </div>
            <div class="project-item" data-aos="fade-left">
                <div class="project-info">
                    <h3>ACE Project</h3>
                    <p>Integration of technical and professional skills for industry readiness.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="gallery">
        <h2 class="section-header" data-aos="fade-up">Gallery</h2>
        <div class="gallery-container" data-aos="zoom-in">
            <div class="gallery-item"><img src="assets/event1.jpg" alt="Event Photo"></div>
            <div class="gallery-item"><img src="assets/cert1-img.jpg" alt="Certificate Preview"></div>
            <div class="gallery-item"><img src="assets/event2.jpg" alt="Project Presentation"></div>
        </div>
    </section>

    <footer id="contact">
        <div class="footer-content" data-aos="fade-up">
            <h2>Let's Get In Touch</h2>
            <p><i class="fas fa-envelope"></i> shaikhmdfarhan9@gmail.com</p>
            <p><i class="fas fa-phone"></i> +91 7888136855</p>
            <div class="social-icons">
                <a href="#"><i class="fab fa-linkedin"></i></a>
                <a href="#"><i class="fab fa-github"></i></a>
            </div>
            <hr>
            <p>© 2026 Md. Farhan Shaikh | All Rights Reserved</p>
        </div>
    </footer>

